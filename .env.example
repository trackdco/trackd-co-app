# Supabase - client/browser + SSR (browser-safe, MUST keep NEXT_PUBLIC_ prefix)
# These are inlined into the client bundle at BUILD time (next build), not read at runtime.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Supabase - server-only secret key (successor to service_role JWT).
# NO NEXT_PUBLIC_ prefix - server-only, never inlined into the browser bundle.
# Needed by the Phase-2 reminder scheduler route (/api/notifications/run) to read
# other users' due doses + subscriptions with the service role. Get it from the
# Supabase dashboard (Settings -> API -> secret key) and set it in Vercel.
# SUPABASE_SECRET_KEY=sb_secret_your-key-here

# Reminder scheduler (Spec 14 Phase 2) - shared secret the Supabase pg_cron job
# sends as a Bearer token when it calls /api/notifications/run. Server-only. Set
# the SAME value in Vercel and in the pg_cron job. Only needed to turn ON the
# AUTOMATIC scheduler; the in-app "Send a test notification" works without it.
# CRON_SECRET=a-long-random-string

# Web Push - VAPID public key (Spec 14). Browser-safe, inlined at BUILD time, so it
# MUST keep the NEXT_PUBLIC_ prefix and be set in Vercel (Prod + Preview), then
# redeploy without build cache. Generate the keypair once (npx web-push
# generate-vapid-keys, or scripts equivalent).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-base64url

# Web Push - SERVER-side VAPID private key, used by the in-app Phase-1 test sender
# (web-push in a server action). NO NEXT_PUBLIC_ prefix — the private key must
# never reach the client bundle. This is the ONLY extra var Vercel needs beyond
# the NEXT_PUBLIC public key above (the sender reuses that for the public half):
VAPID_PRIVATE_KEY=your-vapid-private-key-base64url
# Optional overrides (sensible defaults in code — usually leave unset):
#   VAPID_PUBLIC_KEY  = (defaults to NEXT_PUBLIC_VAPID_PUBLIC_KEY)
#   VAPID_SUBJECT     = mailto:notifications@trackdco.app
# The Phase-2 reminder scheduler (supabase/functions/send-push) sets these same
# values as Supabase Edge Function secrets when it's deployed.

# Stripe - subscriptions (Billing spec). TEST/sandbox keys for dev; LIVE keys are
# set ONLY in Vercel, never here. All development runs in a Stripe sandbox.
# Publishable key - browser-safe, inlined at BUILD time, MUST keep NEXT_PUBLIC_.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
# Secret key - SERVER-ONLY, no NEXT_PUBLIC_. Dashboard -> Developers -> API keys.
STRIPE_SECRET_KEY=sk_test_your-key-here
# Webhook signing secret - SERVER-ONLY. From the webhook endpoint you create, or
# from `stripe listen` during local development. Starts with whsec_.
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
# Recurring Price IDs (NOT secret) - Product "Trackd Co" -> monthly & yearly price.
STRIPE_PRICE_MONTHLY=price_your-monthly-id
STRIPE_PRICE_ANNUAL=price_your-annual-id
# Beta access code - SERVER-ONLY (no NEXT_PUBLIC_). Testers enter this on the
# pricing page to get a 14-day trial instead of 7. Any string; case-insensitive.
BETA_ACCESS_CODE=TRACKDBETA
# NOTE: the webhook ALSO needs SUPABASE_SECRET_KEY (above) - it writes profiles.tier
# and the subscriptions row with the service role, bypassing RLS.
