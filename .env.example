# Supabase - client/browser + SSR (browser-safe, MUST keep NEXT_PUBLIC_ prefix)
# These are inlined into the client bundle at BUILD time (next build), not read at runtime.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Supabase - server-only secret key (successor to service_role JWT).
# NO NEXT_PUBLIC_ prefix - server-only, never inlined into the browser bundle.
# Add this only once the sb_secret_ value is available; required only for admin/RLS-bypassing
# operations (none of the current SSR client files use it).
# SUPABASE_SECRET_KEY=sb_secret_your-key-here

# Web Push - VAPID public key (Spec 14). Browser-safe, inlined at BUILD time, so it
# MUST keep the NEXT_PUBLIC_ prefix and be set in Vercel (Prod + Preview), then
# redeploy without build cache. Generate the keypair once (npx web-push
# generate-vapid-keys, or scripts equivalent).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-base64url

# Web Push - SERVER-side VAPID, used by the in-app Phase-1 test sender (web-push in
# a server action). NO NEXT_PUBLIC_ prefix — the private key must never reach the
# client bundle. Set these in Vercel (Production + Preview) so the "Send test
# notification" button works as soon as the app is deployed (no Supabase function
# deploy needed for Phase 1):
VAPID_PUBLIC_KEY=your-vapid-public-key-base64url
VAPID_PRIVATE_KEY=your-vapid-private-key-base64url
VAPID_SUBJECT=mailto:notifications@trackdco.app
# The same three are ALSO set as Supabase Edge Function secrets when the Phase-2
# reminder scheduler (which calls supabase/functions/send-push) is deployed.
